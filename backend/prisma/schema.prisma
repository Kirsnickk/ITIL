// This is the Prisma schema file for ITIL Asset Management
// Database: PostgreSQL on Railway
// Part 1: Generator, datasource, and core user/auth models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTHENTICATION
// ============================================

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  username        String      @unique
  passwordHash    String
  firstName       String
  lastName        String
  role            UserRole    @default(USER)
  departmentId    String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  department      Department? @relation(fields: [departmentId], references: [id])
  assetsAssigned  Asset[]     @relation("AssignedToUser")
  procurementRequests ProcurementRequest[]
  approvals       Approval[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@index([email])
  @@index([departmentId])
  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  USER
  VIEWER
}

// ============================================
// DEPARTMENTS & LOCATIONS
// ============================================

model Department {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  managerId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users       User[]
  assets      Asset[]
  procurementRequests ProcurementRequest[]

  @@index([code])
  @@map("departments")
}

model Location {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  type        LocationType
  country     String
  city        String?
  address     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  assets      Asset[]

  @@index([code])
  @@index([country])
  @@map("locations")
}

enum LocationType {
  OFFICE
  STORE
  WAREHOUSE
  TRANSITION
}

// ============================================
// ASSETS
// ============================================

model Asset {
  id              String       @id @default(uuid())
  assetTag        String       @unique
  name            String
  type            AssetType
  category        String?
  serialNumber    String?
  model           String?
  manufacturer    String?
  purchaseDate    DateTime?
  purchaseCost    Decimal?     @db.Decimal(12, 2)
  warrantyExpiry  DateTime?
  status          AssetStatus  @default(AVAILABLE)
  condition       String?
  locationId      String?
  departmentId    String?
  assignedToId    String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  location        Location?    @relation(fields: [locationId], references: [id])
  department      Department?  @relation(fields: [departmentId], references: [id])
  assignedTo      User?        @relation("AssignedToUser", fields: [assignedToId], references: [id])
  maintenanceRecords MaintenanceRecord[]
  attachments     Attachment[]
  changeHistory   ChangeHistory[]

  @@index([assetTag])
  @@index([type])
  @@index([status])
  @@index([locationId])
  @@index([departmentId])
  @@index([assignedToId])
  @@map("assets")
}

enum AssetType {
  LAPTOP
  DESKTOP
  MONITOR
  PRINTER
  SCANNER
  NETWORK_DEVICE
  SERVER
  MOBILE_DEVICE
  TABLET
  PERIPHERAL
  OTHER
}

enum AssetStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  REPAIR
  RETIRED
  LOST
  DAMAGED
}

// ============================================
// PROCUREMENT
// ============================================

model ProcurementRequest {
  id              String              @id @default(uuid())
  requestNumber   String              @unique
  title           String
  description     String?
  requestorId     String
  departmentId    String
  estimatedCost   Decimal?            @db.Decimal(12, 2)
  actualCost      Decimal?            @db.Decimal(12, 2)
  priority        Priority            @default(MEDIUM)
  status          ProcurementStatus   @default(DRAFT)
  requestDate     DateTime            @default(now())
  approvedDate    DateTime?
  completedDate   DateTime?
  vendor          String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  requestor       User                @relation(fields: [requestorId], references: [id])
  department      Department          @relation(fields: [departmentId], references: [id])
  approvals       Approval[]
  attachments     Attachment[]

  @@index([requestNumber])
  @@index([status])
  @@index([requestorId])
  @@index([departmentId])
  @@map("procurement_requests")
}

enum ProcurementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================
// LICENSES
// ============================================

model License {
  id              String        @id @default(uuid())
  licenseKey      String        @unique
  product         String
  vendor          String
  type            LicenseType
  seatsTotal      Int
  seatsUsed       Int           @default(0)
  purchaseDate    DateTime
  expiryDate      DateTime?
  cost            Decimal?      @db.Decimal(12, 2)
  renewalCost     Decimal?      @db.Decimal(12, 2)
  status          LicenseStatus @default(ACTIVE)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([licenseKey])
  @@index([product])
  @@index([status])
  @@index([expiryDate])
  @@map("licenses")
}

enum LicenseType {
  PERPETUAL
  SUBSCRIPTION
  TRIAL
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_RENEWAL
}

// ============================================
// MAINTENANCE & APPROVALS
// ============================================

model MaintenanceRecord {
  id              String              @id @default(uuid())
  assetId         String
  type            MaintenanceType
  description     String
  performedBy     String?
  vendor          String?
  cost            Decimal?            @db.Decimal(12, 2)
  startDate       DateTime
  completedDate   DateTime?
  status          MaintenanceStatus   @default(SCHEDULED)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  asset           Asset               @relation(fields: [assetId], references: [id])
  attachments     Attachment[]

  @@index([assetId])
  @@index([status])
  @@map("maintenance_records")
}

enum MaintenanceType {
  REPAIR
  UPGRADE
  INSPECTION
  CLEANING
  PREVENTIVE
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Approval {
  id              String          @id @default(uuid())
  procurementId   String
  approverId      String
  status          ApprovalStatus  @default(PENDING)
  comments        String?
  approvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  procurement     ProcurementRequest @relation(fields: [procurementId], references: [id])
  approver        User               @relation(fields: [approverId], references: [id])

  @@index([procurementId])
  @@index([approverId])
  @@index([status])
  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================
// ATTACHMENTS & HISTORY
// ============================================

model Attachment {
  id              String      @id @default(uuid())
  filename        String
  originalName    String
  mimeType        String
  size            Int
  url             String
  assetId         String?
  procurementId   String?
  maintenanceId   String?
  uploadedAt      DateTime    @default(now())

  // Relations
  asset           Asset?              @relation(fields: [assetId], references: [id])
  procurement     ProcurementRequest? @relation(fields: [procurementId], references: [id])
  maintenance     MaintenanceRecord?  @relation(fields: [maintenanceId], references: [id])

  @@index([assetId])
  @@index([procurementId])
  @@index([maintenanceId])
  @@map("attachments")
}

model ChangeHistory {
  id              String    @id @default(uuid())
  assetId         String
  field           String
  oldValue        String?
  newValue        String?
  changedBy       String?
  changedAt       DateTime  @default(now())

  // Relations
  asset           Asset     @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([changedAt])
  @@map("change_history")
}

model AuditLog {
  id              String    @id @default(uuid())
  userId          String?
  action          String
  entity          String
  entityId        String?
  details         String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  // Relations
  user            User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id              String            @id @default(uuid())
  userId          String
  type            NotificationType
  title           String
  message         String
  isRead          Boolean           @default(false)
  createdAt       DateTime          @default(now())

  // Relations
  user            User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  ASSET_ASSIGNED
  MAINTENANCE_DUE
  LICENSE_EXPIRING
  PROCUREMENT_APPROVED
  PROCUREMENT_REJECTED
  SYSTEM_ALERT
}
